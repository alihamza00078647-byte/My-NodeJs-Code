<%- include('partials/head') %>
    <style>
        .home{
            height: 90vh;
            width: 90vw;
            border: 2px solid black;
            margin: 1rem auto;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
        }
        img{
            height: 90%;
            width: 100%;
            object-fit: cover;
        }
    </style>
</head>
<body>
    <header>
        <h1 style="background-color: #f64d47; color: white; font-weight: 600; text-align: center; padding: 6px;">Welcome To airbnb</h1>
        <div class="bg-orange-600 text-xl p-10 text-white ">
            <a style="text-decoration: none; background-color: orangered; border: none; text-align: center; padding: 10px; border-radius: 6px; font-size: 1.1rem; font-weight: 600; color:white" href="/add-home">Add Home</a>
        </div>
        <div class="home">
            <% registeredHomes.forEach(homes => { %>
            <ul style="height: 15rem; background-color: lightgray; width: 12rem; list-style: none; display: flex; flex-direction: column;">
                    <img src="https://plus.unsplash.com/premium_photo-1684508638760-72ad80c0055f?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MXx8YWlyYm5ifGVufDB8fDB8fHww" alt="Not">
                    <li>
                        <span><%= homes.houseName %></span>
                        <span><%= homes.price %></span>
                        <span><%= homes.location %></span>
                        <span><%= homes.rating %></span>
                    </li>
                </ul>
            <% }); %>
        </div>
    </header>
</body>
</html>